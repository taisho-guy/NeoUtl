// src/ui/types.slint

export struct TimelineObject {
    id: int,
    start-frame: int,
    end-frame: int,
    kind: int,
    layer: int,
    label: string,
    selected: bool,
}

export struct ObjectKindItem {
    kind: int,
    name: string,
}

export struct LayerState {
    visible: bool,
    locked: bool,
}

export struct EffectRow {
    index: int,
    name: string,
    enabled: bool,
}

// kind: 0=Float, 1=Bool, 2=Color, 3=Text
// effect-index: -1=オブジェクト直下パラメータ, 0以上=エフェクトスタックのインデックス
// group: セクション見出し（トランスフォーム/テキスト/図形/オーディオ/プラグイン名、エフェクトはエフェクト名）
// text: kind==3のときのみ使用する文字列値。それ以外のkindでは空文字。
export struct ParamRow {
    effect-index: int,
    key: string,
    label: string,
    group: string,
    value: float,
    kind: int,
    min: float,
    max: float,
    text: string,
}

export struct CatalogRow {
    id: string,
    name: string,
}

export struct ProjectListItem {
    name: string,
    path: string,
    width: int,
    height: int,
    fps: int,
}

export struct ProjectTabItem {
    index: int,
    name: string,
    active: bool,
}

export struct SceneTabItem {
    id: int,
    name: string,
    active: bool,
}

