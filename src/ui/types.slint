// src/ui/types.slint

export struct TimelineObject {
    id: int,
    start-frame: int,
    end-frame: int,
    kind: int,
    layer: int,
    label: string,
    selected: bool,
}

export struct ObjectKindItem {
    kind: int,
    name: string,
}

export struct LayerState {
    visible: bool,
    locked: bool,
}

export struct EffectRow {
    index: int,
    name: string,
    enabled: bool,
}

// kind: 0=Float, 1=Bool, 2=Color
export struct ParamRow {
    effect-index: int,
    key: string,
    label: string,
    value: float,
    kind: int,
    min: float,
    max: float,
}

export struct CatalogRow {
    id: string,
    name: string,
}

export struct ProjectListItem {
    name: string,
    path: string,
    width: int,
    height: int,
    fps: int,
}

export struct ProjectTabItem {
    index: int,
    name: string,
    active: bool,
}

export struct SceneTabItem {
    id: int,
    name: string,
    active: bool,
}
