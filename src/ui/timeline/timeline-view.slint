// src/ui/timeline/timeline-view.slint
import { TimelineObject, LayerState } from "../types.slint";
import { TimelineGrid } from "timeline-grid.slint";
import { ClipItem } from "clip-item.slint";

export component TimelineView inherits Rectangle {
    in property <float> scale: 1.0;
    in property <int> frame-interval: 30;
    in property <int> total-frames: 300;
    in property <int> layer-count: 128;
    in property <length> layer-height: 24px;
    in property <int> current-frame: 0;
    in property <[TimelineObject]> objects: [];
    in property <[LayerState]> layer-states: [];
    in property <length> scroll-x: 0px;
    in property <length> scroll-y: 0px;

    callback seek(int);
    callback context-menu(length, length, int /* frame */, int /* layer */, int /* hit-id */);
    callback select-object(int);
    callback move-object(int, int, int);
    callback resize-object(int, int, int);
    callback scroll-requested(length /* wheel delta-y, consumed as horizontal scroll */);

    function px-to-frame(px: length) -> int {
        return max(0, floor((px + root.scroll-x) / root.scale / 1px));
    }
    function px-to-layer(px: length) -> int {
        return max(0, floor((px + root.scroll-y) / root.layer-height));
    }
    function is-layer-locked(layer: int) -> bool {
        return layer >= 0 && layer < root.layer-states.length && root.layer-states[layer].locked;
    }

    background: #17171b;
    clip: true;

    content := Rectangle {
        x: -root.scroll-x;
        y: -root.scroll-y;
        width: max(root.width, root.total-frames * root.scale * 1px);
        height: root.layer-count * root.layer-height;

        TimelineGrid {
            width: 100%;
            height: 100%;
            scale: root.scale;
            frame-interval: root.frame-interval;
            layer-count: root.layer-count;
            layer-height: root.layer-height;
        }

        bg-touch := TouchArea {
            pointer-event(e) => {
                if (e.kind != PointerEventKind.down) { return; }
                if (e.button == PointerEventButton.left) {
                    root.seek(root.px-to-frame(self.pressed-x));
                } else if (e.button == PointerEventButton.right) {
                    root.context-menu(self.absolute-position.x + self.pressed-x, self.absolute-position.y + self.pressed-y, root.px-to-frame(self.pressed-x), root.px-to-layer(self.pressed-y), -1);
                }
            }
            scroll-event(e) => {
                root.scroll-requested(e.delta-y);
                return accept;
            }
        }

        for obj in root.objects: ClipItem {
            obj: obj;
            scale: root.scale;
            layer-height: root.layer-height;
            locked: root.is-layer-locked(obj.layer);
            clicked(id) => { root.select-object(id); }
            moved(id, start, layer) => { root.move-object(id, start, layer); }
            resized(id, start, end) => { root.resize-object(id, start, end); }
            context-requested(id, x, y) => { root.context-menu(x, y, obj.start-frame, obj.layer, id); }
        }

        Rectangle {
            x: root.current-frame * root.scale * 1px;
            width: 2px;
            height: parent.height;
            background: #ff450088;
        }
    }
}
