// src/ui/properties.slint
import { Slider } from "std-widgets.slint";
import { EffectRow, ParamRow, CatalogRow } from "types.slint";

component PropertyRow inherits Rectangle {
    in property <string> label;
    in property <float> value;
    in property <float> min: -1000;
    in property <float> max: 1000;
    in property <float> drag-sensitivity: 1;
    callback changed(float);

    height: 22px;

    function clamp(v: float) -> float {
        return v < min ? min : v > max ? max : v;
    }

    // ドラッグ中の直前座標。press開始フレームはmoved内で初期化する
    // （pressed変化を検知するための1フレーム目フラグ方式）。
    property <length> anchor-x: 0;
    property <length> anchor-y: 0;
    property <bool> was-pressed: false;

    HorizontalLayout {
        spacing: 4px;

        Rectangle {
            width: 74px;
            background: #202026;
            Text { text: label; color: #b0b0ba; font-size: 11px; horizontal-alignment: center; vertical-alignment: center; width: 100%; height: 100%; }
        }

        // Slider・ボックスとも同一のroot.value/root.changedのみを介して読み書きする。
        // 個々に内部stateを持たせない（＝リンク切れの原因を構造的に排除する）。
        Slider {
            minimum: root.min;
            maximum: root.max;
            value: root.value;
            changed(v) => { root.changed(root.clamp(v)); }
        }

        Rectangle {
            width: 64px;
            border-radius: 3px;
            background: drag-area.pressed ? #22222a : #16161b;
            border-width: 1px;
            border-color: #303038;

            input := TextInput {
                x: 4px;
                width: parent.width - 8px;
                height: 100%;
                text: root.value;
                color: #dde3ee;
                font-size: 11px;
                horizontal-alignment: center;
                vertical-alignment: center;
                input-type: InputType.decimal;
                accepted => { root.changed(root.clamp(self.text.to-float())); }
            }

            // ドラッグ量=移動量そのもの。画面端到達でそれ以上は追従不能
            // （Slintにポインタロック/warp APIが無いための既知の制約）。
            drag-area := TouchArea {
                mouse-cursor: self.pressed ? MouseCursor.none : MouseCursor.default;
                clicked => { input.focus(); }
                moved => {
                    if (self.pressed) {
                        if (!root.was-pressed) {
                            root.was-pressed = true;
                            root.anchor-x = self.mouse-x;
                            root.anchor-y = self.mouse-y;
                        } else {
                            root.changed(root.clamp(root.value
                                + (self.mouse-x - root.anchor-x) / 1px * root.drag-sensitivity
                                - (self.mouse-y - root.anchor-y) / 1px * root.drag-sensitivity));
                            root.anchor-x = self.mouse-x;
                            root.anchor-y = self.mouse-y;
                        }
                    } else {
                        root.was-pressed = false;
                    }
                }
            }
        }
    }
}

component ToggleField inherits Rectangle {
    in property <string> label;
    in property <bool> checked;
    callback toggled();

    height: 22px;

    Text {
        text: label;
        color: #b0b0ba;
        font-size: 11px;
        vertical-alignment: center;
        height: 100%;
    }

    Rectangle {
        x: parent.width - 36px;
        width: 36px;
        height: 18px;
        border-radius: 9px;
        background: checked ? #2a4db8 : #303038;

        Rectangle {
            x: checked ? parent.width - 16px : 2px;
            y: 2px;
            width: 14px;
            height: 14px;
            border-radius: 7px;
            background: #e8e8ee;
        }

        TouchArea { clicked() => { root.toggled(); } }
    }
}

component SectionHeader inherits Text {
    color: #55555e;
    font-size: 10px;
    font-weight: 700;
}

// ParamRow.kindに応じた描画を一本化する標準コンポーネント。
// object-params/エフェクトパラメータの両呼び出し元がこれのみを使う。
// kind: 0=Float(スライダー+数値ボックス), 1=Bool(トグル), 2=Color(0..1スライダー)。
// 新規kindの追加時はここに分岐を1件足すだけで全呼び出し元に反映される。
component ParamField inherits Rectangle {
    in property <ParamRow> data;
    callback changed-float(float);
    callback changed-bool(bool);
    callback changed-text(string);

    height: data.kind == 3 ? 44px : 22px;

    if data.kind == 0: PropertyRow {
        label: data.label;
        value: data.value;
        min: data.min;
        max: data.max;
        changed(v) => { root.changed-float(v); }
    }

    if data.kind == 1: ToggleField {
        label: data.label;
        checked: data.value > 0.5;
        toggled => { root.changed-bool(data.value <= 0.5); }
    }

    if data.kind == 2: PropertyRow {
        label: data.label;
        value: data.value;
        min: 0;
        max: 1;
        changed(v) => { root.changed-float(v); }
    }

    if data.kind == 3: Rectangle {
        height: 44px;
        border-radius: 3px;
        background: #1e1e24;
        border-width: 1px;
        border-color: #303038;

        TextInput {
            x: 6px; y: 4px;
            width: parent.width - 12px;
            height: parent.height - 8px;
            text: data.text;
            color: #dde3ee;
            font-size: 11px;
            wrap: word-wrap;
            accepted => { root.changed-text(self.text); }
        }
    }
}

export component PropertiesWindow inherits Window {
    title: "NeoUtl - オブジェクト設定";
    preferred-width: 620px;
    preferred-height: 640px;
    background: #0e0e12;

    in-out property <int> object-id: -1;
    in-out property <float> stage-width: 1920;
    in-out property <float> stage-height: 1080;

    in-out property <bool> has-transform: false;
    in-out property <bool> has-text: false;
    in-out property <bool> has-shape: false;
    in-out property <bool> has-audio: false;

    // Transform/Text/Shape/Audioの数値・真偽値・文字列項目はすべてこの一本のリストに統一する。
    // 並び順・ラベル・レンジ・種別はRust側object_schema.rsのみが決定し、ここでは
    // kind別（0=Float,1=Bool,2=Color,3=Text）の描画分岐のみを行う（型別ハードコード撤廃）。
    in-out property <[ParamRow]> object-params: [];

    in-out property <[EffectRow]> effects: [];
    in-out property <[ParamRow]> params: [];
    in property <[CatalogRow]> effect-catalog: [];
    in-out property <bool> catalog-open: false;

    callback set-object-param(string, string, float);
    callback set-object-param-bool(string, string, bool);
    callback set-object-param-text(string, string, string);
    callback set-effect-enabled(int, bool);
    callback remove-effect(int);
    callback set-param(int, string, float);
    callback set-param-bool(int, string, bool);
    callback add-effect(string);
    callback move-effect(int, int);

    if object-id < 0: Text {
        text: "オブジェクトが選択されていません";
        color: #55555e;
        font-size: 12px;
        horizontal-alignment: center;
        vertical-alignment: center;
        width: 100%;
        height: 100%;
    }

    if object-id >= 0: Flickable {
        VerticalLayout {
            padding: 10px;
            spacing: 8px;

            for p[j] in root.object-params: VerticalLayout {
                spacing: 4px;

                if j == 0 || p.group != root.object-params[j - 1].group: VerticalLayout {
                    spacing: 4px;
                    Rectangle { height: 1px; background: #24242c; }
                    SectionHeader { text: p.group; }
                }

                if p.kind == 0: ParamField {
                    data: p;
                    changed-float(v) => { root.set-object-param(p.group, p.key, v); }
                }

                if p.kind == 1: ParamField {
                    data: p;
                    changed-bool(v) => { root.set-object-param-bool(p.group, p.key, v); }
                }

                if p.kind == 2: ParamField {
                    data: p;
                    changed-float(v) => { root.set-object-param(p.group, p.key, v); }
                }

                if p.kind == 3: ParamField {
                    data: p;
                    changed-text(v) => { root.set-object-param-text(p.group, p.key, v); }
                }
            }

            Rectangle { height: 1px; background: #24242c; }

            HorizontalLayout {
                height: 20px;
                spacing: 6px;
                SectionHeader { text: "エフェクト"; vertical-alignment: center; height: 100%; }
                Rectangle {
                    width: 60px;
                    height: 18px;
                    border-radius: 3px;
                    background: #1e1e24;
                    border-width: 1px;
                    border-color: #303038;
                    Text { text: "追加"; color: #8a8a96; font-size: 10px; horizontal-alignment: center; vertical-alignment: center; width: 100%; height: 100%; }
                    TouchArea { clicked() => { root.catalog-open = !root.catalog-open; } }
                }
            }

            if root.catalog-open: VerticalLayout {
                spacing: 1px;
                for c[k] in root.effect-catalog: Rectangle {
                    height: 20px;
                    background: #16161b;
                    Text { x: 6px; text: c.name; color: #b0b0ba; font-size: 10px; vertical-alignment: center; height: 100%; }
                    TouchArea { clicked() => { root.add-effect(c.id); root.catalog-open = false; } }
                }
            }

            for eff[i] in root.effects: VerticalLayout {
                spacing: 2px;

                Rectangle {
                    height: 24px;
                    background: #16161b;

                    HorizontalLayout {
                        padding-left: 4px;
                        padding-right: 4px;
                        spacing: 6px;

                        ToggleField {
                            width: 30px;
                            label: "";
                            checked: eff.enabled;
                            toggled => { root.set-effect-enabled(eff.index, !eff.enabled); }
                        }

                        Text {
                            text: eff.name;
                            color: #c8c8d2;
                            font-size: 11px;
                            vertical-alignment: center;
                            height: 100%;
                        }

                        Rectangle {
                            width: 14px;
                            height: 14px;
                            visible: eff.index > 0;
                            Text { text: "▲"; color: #888894; font-size: 9px; horizontal-alignment: center; vertical-alignment: center; width: 100%; height: 100%; }
                            TouchArea { clicked() => { root.move-effect(eff.index, eff.index - 1); } }
                        }

                        Rectangle {
                            width: 14px;
                            height: 14px;
                            visible: eff.index < root.effects.length - 1;
                            Text { text: "▼"; color: #888894; font-size: 9px; horizontal-alignment: center; vertical-alignment: center; width: 100%; height: 100%; }
                            TouchArea { clicked() => { root.move-effect(eff.index, eff.index + 1); } }
                        }

                        Rectangle {
                            width: 18px;
                            height: 18px;
                            TouchArea { clicked() => { root.remove-effect(eff.index); } }
                            Text { text: "×"; color: #888894; horizontal-alignment: center; vertical-alignment: center; width: 100%; height: 100%; }
                        }
                    }
                }

                // paramsはParamRow.kindに応じ、ParamFieldが標準描画へ振り分ける。
                for p[j] in root.params: Rectangle {
                    height: p.effect-index == eff.index ? 22px : 0px;
                    clip: true;

                    if p.effect-index == eff.index: ParamField {
                        data: p;
                        changed-float(v) => { root.set-param(eff.index, p.key, v); }
                        changed-bool(v) => { root.set-param-bool(eff.index, p.key, v); }
                    }
                }
            }
        }
    }
}

