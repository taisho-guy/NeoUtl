// src/ui/properties.slint
import { EffectRow, ParamRow, CatalogRow } from "types.slint";

component PropertyRow inherits Rectangle {
    in property <string> label;
    in property <float> value;
    in property <float> min: -1000;
    in property <float> max: 1000;
    callback changed(float);

    height: 22px;

    function clamp(v: float) -> float {
        return v < min ? min : v > max ? max : v;
    }

    HorizontalLayout {
        spacing: 4px;

        Rectangle {
            background: #1e1e24;
            Rectangle {
                x: 0;
                width: parent.width * ((root.value - root.min) / (root.max - root.min));
                height: 100%;
                background: #2a4db8;
            }
            TouchArea {
                moved => {
                    if (self.pressed) {
                        root.changed(root.clamp(root.min + (self.mouse-x / parent.width) * (root.max - root.min)));
                    }
                }
            }
        }

        Rectangle {
            width: 64px;
            border-radius: 3px;
            background: #16161b;
            border-width: 1px;
            border-color: #303038;
            TextInput {
                x: 4px;
                width: parent.width - 8px;
                height: 100%;
                text: value;
                color: #dde3ee;
                font-size: 11px;
                horizontal-alignment: center;
                vertical-alignment: center;
                input-type: InputType.decimal;
                accepted => { root.changed(root.clamp(self.text.to-float())); }
            }
        }

        Rectangle {
            width: 74px;
            background: #202026;
            Text { text: label; color: #b0b0ba; font-size: 11px; horizontal-alignment: center; vertical-alignment: center; width: 100%; height: 100%; }
        }

        Rectangle {
            width: 64px;
            border-radius: 3px;
            background: #16161b;
            border-width: 1px;
            border-color: #303038;
            TextInput {
                x: 4px;
                width: parent.width - 8px;
                height: 100%;
                text: value;
                color: #dde3ee;
                font-size: 11px;
                horizontal-alignment: center;
                vertical-alignment: center;
                input-type: InputType.decimal;
                accepted => { root.changed(root.clamp(self.text.to-float())); }
            }
        }

        Rectangle {
            background: #1e1e24;
            Rectangle {
                x: 0;
                width: parent.width * ((root.value - root.min) / (root.max - root.min));
                height: 100%;
                background: #2a4db8;
            }
            TouchArea {
                moved => {
                    if (self.pressed) {
                        root.changed(root.clamp(root.min + (self.mouse-x / parent.width) * (root.max - root.min)));
                    }
                }
            }
        }
    }
}

component ToggleField inherits Rectangle {
    in property <string> label;
    in property <bool> checked;
    callback toggled();

    height: 22px;

    Text {
        text: label;
        color: #b0b0ba;
        font-size: 11px;
        vertical-alignment: center;
        height: 100%;
    }

    Rectangle {
        x: parent.width - 36px;
        width: 36px;
        height: 18px;
        border-radius: 9px;
        background: checked ? #2a4db8 : #303038;

        Rectangle {
            x: checked ? parent.width - 16px : 2px;
            y: 2px;
            width: 14px;
            height: 14px;
            border-radius: 7px;
            background: #e8e8ee;
        }

        TouchArea { clicked() => { root.toggled(); } }
    }
}

component SectionHeader inherits Text {
    color: #55555e;
    font-size: 10px;
    font-weight: 700;
}

export component PropertiesWindow inherits Window {
    title: "NeoUtl - オブジェクト設定";
    preferred-width: 620px;
    preferred-height: 560px;
    background: #0e0e12;

    in-out property <int> object-id: -1;

    in-out property <bool> has-transform: false;
    in-out property <float> tx: 0;
    in-out property <float> ty: 0;
    in-out property <float> tz: 0;
    in-out property <float> scale-x: 1;
    in-out property <float> scale-y: 1;
    in-out property <float> rot-x: 0;
    in-out property <float> rot-y: 0;
    in-out property <float> rot-z: 0;
    in-out property <float> obj-opacity: 1;

    in-out property <bool> has-text: false;
    in-out property <string> text-content: "";
    in-out property <float> text-x: 0;
    in-out property <float> text-y: 0;
    in-out property <float> text-font-size: 48;

    in-out property <bool> has-audio: false;
    in-out property <float> volume: 1;
    in-out property <float> pan: 0;
    in-out property <bool> mute: false;

    in-out property <[EffectRow]> effects: [];
    in-out property <[ParamRow]> params: [];
    in property <[CatalogRow]> effect-catalog: [];
    in-out property <bool> catalog-open: false;

    callback set-transform(float, float, float, float, float, float, float, float, float);
    callback set-text(string, float, float, float);
    callback set-audio(float, float, bool);
    callback set-effect-enabled(int, bool);
    callback remove-effect(int);
    callback set-param(int, string, float);
    callback add-effect(string);
    callback move-effect(int, int);

    function emit-transform() {
        root.set-transform(root.tx, root.ty, root.tz, root.scale-x, root.scale-y, root.rot-x, root.rot-y, root.rot-z, root.obj-opacity);
    }

    if object-id < 0: Text {
        text: "オブジェクト未選択";
        color: #55555e;
        font-size: 12px;
        horizontal-alignment: center;
        vertical-alignment: center;
        width: 100%;
        height: 100%;
    }

    if object-id >= 0: VerticalLayout {
            padding: 10px;
            spacing: 8px;

            if has-transform: VerticalLayout {
                spacing: 4px;
                SectionHeader { text: "トランスフォーム"; }
                PropertyRow { label: "X"; value: root.tx; min: -1000; max: 1000; changed(v) => { root.tx = v; root.emit-transform(); } }
                PropertyRow { label: "Y"; value: root.ty; min: -1000; max: 1000; changed(v) => { root.ty = v; root.emit-transform(); } }
                PropertyRow { label: "Z"; value: root.tz; min: -1000; max: 1000; changed(v) => { root.tz = v; root.emit-transform(); } }
                PropertyRow { label: "拡大率X"; value: root.scale-x; min: 0; max: 10; changed(v) => { root.scale-x = v; root.emit-transform(); } }
                PropertyRow { label: "拡大率Y"; value: root.scale-y; min: 0; max: 10; changed(v) => { root.scale-y = v; root.emit-transform(); } }
                PropertyRow { label: "X軸回転"; value: root.rot-x; min: -360; max: 360; changed(v) => { root.rot-x = v; root.emit-transform(); } }
                PropertyRow { label: "Y軸回転"; value: root.rot-y; min: -360; max: 360; changed(v) => { root.rot-y = v; root.emit-transform(); } }
                PropertyRow { label: "Z軸回転"; value: root.rot-z; min: -360; max: 360; changed(v) => { root.rot-z = v; root.emit-transform(); } }
                PropertyRow { label: "不透明度"; value: root.obj-opacity; min: 0; max: 1; changed(v) => { root.obj-opacity = v; root.emit-transform(); } }
            }

            if has-text: VerticalLayout {
                spacing: 4px;
                Rectangle { height: 1px; background: #24242c; }
                SectionHeader { text: "テキスト"; }
                Rectangle {
                    height: 44px;
                    border-radius: 3px;
                    background: #1e1e24;
                    border-width: 1px;
                    border-color: #303038;

                    TextInput {
                        x: 6px; y: 4px;
                        width: parent.width - 12px;
                        height: parent.height - 8px;
                        text: root.text-content;
                        color: #dde3ee;
                        font-size: 11px;
                        wrap: word-wrap;
                        accepted => { root.text-content = self.text; root.set-text(self.text, root.text-x, root.text-y, root.text-font-size); }
                    }
                }
                PropertyRow { label: "X"; value: root.text-x; min: -1000; max: 1000; changed(v) => { root.text-x = v; root.set-text(root.text-content, v, root.text-y, root.text-font-size); } }
                PropertyRow { label: "Y"; value: root.text-y; min: -1000; max: 1000; changed(v) => { root.text-y = v; root.set-text(root.text-content, root.text-x, v, root.text-font-size); } }
                PropertyRow { label: "フォントサイズ"; value: root.text-font-size; min: 1; max: 500; changed(v) => { root.text-font-size = v; root.set-text(root.text-content, root.text-x, root.text-y, v); } }
            }

            if has-audio: VerticalLayout {
                spacing: 4px;
                Rectangle { height: 1px; background: #24242c; }
                SectionHeader { text: "オーディオ"; }
                PropertyRow { label: "音量"; value: root.volume; min: 0; max: 2; changed(v) => { root.volume = v; root.set-audio(v, root.pan, root.mute); } }
                PropertyRow { label: "パン"; value: root.pan; min: -1; max: 1; changed(v) => { root.pan = v; root.set-audio(root.volume, v, root.mute); } }
                ToggleField { label: "ミュート"; checked: root.mute; toggled => { root.mute = !root.mute; root.set-audio(root.volume, root.pan, root.mute); } }
            }

            Rectangle { height: 1px; background: #24242c; }

            HorizontalLayout {
                height: 20px;
                spacing: 6px;
                SectionHeader { text: "エフェクト"; vertical-alignment: center; height: 100%; }
                Rectangle {
                    width: 60px;
                    height: 18px;
                    border-radius: 3px;
                    background: #1e1e24;
                    border-width: 1px;
                    border-color: #303038;
                    Text { text: "追加"; color: #8a8a96; font-size: 10px; horizontal-alignment: center; vertical-alignment: center; width: 100%; height: 100%; }
                    TouchArea { clicked() => { root.catalog-open = !root.catalog-open; } }
                }
            }

            if root.catalog-open: VerticalLayout {
                spacing: 1px;
                for c[k] in root.effect-catalog: Rectangle {
                    height: 20px;
                    background: #16161b;
                    Text { x: 6px; text: c.name; color: #b0b0ba; font-size: 10px; vertical-alignment: center; height: 100%; }
                    TouchArea { clicked() => { root.add-effect(c.id); root.catalog-open = false; } }
                }
            }

            for eff[i] in root.effects: VerticalLayout {
                spacing: 2px;

                Rectangle {
                    height: 24px;
                    background: #16161b;

                    HorizontalLayout {
                        padding-left: 4px;
                        padding-right: 4px;
                        spacing: 6px;

                        ToggleField {
                            width: 30px;
                            label: "";
                            checked: eff.enabled;
                            toggled => { root.set-effect-enabled(eff.index, !eff.enabled); }
                        }

                        Text {
                            text: eff.name;
                            color: #c8c8d2;
                            font-size: 11px;
                            vertical-alignment: center;
                            height: 100%;
                        }

                        Rectangle {
                            width: 14px;
                            height: 14px;
                            visible: eff.index > 0;
                            Text { text: "▲"; color: #888894; font-size: 9px; horizontal-alignment: center; vertical-alignment: center; width: 100%; height: 100%; }
                            TouchArea { clicked() => { root.move-effect(eff.index, eff.index - 1); } }
                        }

                        Rectangle {
                            width: 14px;
                            height: 14px;
                            visible: eff.index < root.effects.length - 1;
                            Text { text: "▼"; color: #888894; font-size: 9px; horizontal-alignment: center; vertical-alignment: center; width: 100%; height: 100%; }
                            TouchArea { clicked() => { root.move-effect(eff.index, eff.index + 1); } }
                        }

                        Rectangle {
                            width: 18px;
                            height: 18px;
                            TouchArea { clicked() => { root.remove-effect(eff.index); } }
                            Text { text: "×"; color: #888894; horizontal-alignment: center; vertical-alignment: center; width: 100%; height: 100%; }
                        }
                    }
                }

                for p[j] in root.params: Rectangle {
                    height: p.effect-index == eff.index ? 22px : 0px;
                    clip: true;

                    if p.effect-index == eff.index: PropertyRow {
                        label: p.key;
                        value: p.value;
                        min: 0;
                        max: 100;
                        changed(v) => { root.set-param(eff.index, p.key, v); }
                    }
                }
            }
    }
}
