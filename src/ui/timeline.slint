// src/ui/timeline.slint
import { TimelineObject } from "types.slint";

export component TimelineWindow inherits Window {
    title: "NeoUtl - 拡張編集";
    preferred-width: 820px;
    preferred-height: 180px;
    background: #0e0e12;

    in-out property <int>              current-frame: 0;
    in-out property <int>              total-frames: 300;
    in-out property <[TimelineObject]> objects: [];

    callback seek-timeline(float);
    callback add-object-at(float, int);
    callback delete-object(int);
    callback move-object(int, float);
    callback find-object-at(float) -> int;
    callback get-object-start-ratio(int) -> float;

    property <bool>   show-context-menu: false;
    property <bool>   menu-is-delete: false;
    property <int>    menu-target-id: -1;
    property <length> menu-x: 0px;
    property <length> menu-y: 0px;
    property <float>  click-ratio: 0.0;

    property <int>    drag-mode: 0;
    property <int>    dragging-obj-id: -1;
    property <length> drag-mouse-start: 0px;
    property <float>  drag-obj-start-ratio: 0.0;

    FocusScope {
        key-pressed(event) => { accept }
        TouchArea {
            pointer-event(e) => {
                if (e.button == PointerEventButton.left && e.kind == PointerEventKind.down) {
                    root.show-context-menu = false;
                }
            }
        }
    }

    VerticalLayout {
        padding: 8px;
        spacing: 6px;

        Text {
            text: "左ドラッグ: シーク  |  オブジェクト左ドラッグ: 移動  |  右クリック: メニュー";
            color: #555560;
            font-size: 10px;
            horizontal-alignment: center;
            height: 14px;
        }

        timeline-rect := Rectangle {
            background: #1a1a20;
            border-radius: 4px;
            border-width: 1px;
            border-color: #2a2a32;

            Rectangle {
                background: #ff4500;
                width: 2px;
                height: parent.height;
                x: (root.current-frame / root.total-frames) * parent.width;
            }

            for obj in root.objects : Rectangle {
                property <bool>  is-drag: root.drag-mode == 2 && root.dragging-obj-id == obj.id;
                property <color> base-color:
                    obj.kind == 0 ? #2a4db8 :
                    obj.kind == 1 ? #256e3c :
                                    #6a2db8;
                property <color> drag-color:
                    obj.kind == 0 ? #4a6fd8 :
                    obj.kind == 1 ? #3d9e5c :
                                    #8a4dd8;
                property <color> border-color-val:
                    obj.kind == 0 ? #6a90f0 :
                    obj.kind == 1 ? #5dc87a :
                                    #aa70f0;

                background: is-drag ? drag-color : base-color;
                border-width: 1px;
                border-color: is-drag ? border-color-val : base-color.darker(0.3);
                border-radius: 3px;
                y: 8px;
                height: parent.height - 16px;
                x: (obj.start-frame / root.total-frames) * parent.width;
                width: ((obj.end-frame - obj.start-frame) / root.total-frames) * parent.width;

                Text {
                    text: obj.label;
                    color: white;
                    font-size: 10px;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                    overflow: elide;
                }
            }

            timeline-touch := TouchArea {
                mouse-cursor: root.drag-mode == 2 ? MouseCursor.grabbing
                            : root.drag-mode == 1 ? MouseCursor.col-resize
                            : MouseCursor.default;

                pointer-event(e) => {
                    if (e.kind == PointerEventKind.down) {
                        root.show-context-menu = false;
                        let press-ratio = self.pressed-x / self.width;

                        if (e.button == PointerEventButton.right) {
                            let hit-id = root.find-object-at(press-ratio);
                            root.click-ratio = press-ratio;
                            root.menu-target-id = hit-id;
                            root.menu-is-delete = hit-id >= 0;
                            root.menu-x = timeline-rect.absolute-position.x + self.pressed-x;
                            root.menu-y = timeline-rect.absolute-position.y + self.pressed-y + 4px;
                            root.show-context-menu = true;
                        } else if (e.button == PointerEventButton.left) {
                            root.drag-mouse-start = self.pressed-x;
                            let hit-id = root.find-object-at(press-ratio);
                            if (hit-id >= 0) {
                                root.drag-mode = 2;
                                root.dragging-obj-id = hit-id;
                                root.drag-obj-start-ratio = root.get-object-start-ratio(hit-id);
                            } else {
                                root.drag-mode = 1;
                                root.seek-timeline(press-ratio);
                            }
                        }
                    }
                    if (e.kind == PointerEventKind.up || e.kind == PointerEventKind.cancel) {
                        root.drag-mode = 0;
                        root.dragging-obj-id = -1;
                    }
                }

                moved() => {
                    if (root.drag-mode == 1) {
                        root.seek-timeline((self.mouse-x / self.width).clamp(0.0, 1.0));
                    } else if (root.drag-mode == 2) {
                        let delta = (self.mouse-x - root.drag-mouse-start) / self.width;
                        let new-r = (root.drag-obj-start-ratio + delta).clamp(0.0, 1.0);
                        root.move-object(root.dragging-obj-id, new-r);
                    }
                }
            }
        }
    }

    if (root.show-context-menu) : Rectangle {
        x: root.menu-x;
        y: root.menu-y;
        width: 170px;
        height: root.menu-is-delete ? 40px : 106px;
        background: #252528;
        border-width: 1px;
        border-color: #48484e;
        border-radius: 5px;
        drop-shadow-blur: 10px;
        drop-shadow-color: #00000088;
        drop-shadow-offset-x: 2px;
        drop-shadow-offset-y: 2px;

        if (root.menu-is-delete) : VerticalLayout {
            padding: 4px;
            Rectangle {
                background: del-touch.has-hover ? #4a1515 : transparent;
                height: 30px;
                border-radius: 3px;
                Text { text: "  🗑  Delete Object"; color: #ff8888; font-size: 12px; vertical-alignment: center; }
                del-touch := TouchArea {
                    clicked() => { root.delete-object(root.menu-target-id); root.show-context-menu = false; }
                }
            }
        }

        if (!root.menu-is-delete) : VerticalLayout {
            padding: 4px;
            spacing: 1px;

            Rectangle {
                background: t-touch.has-hover ? #303038 : transparent;
                height: 30px;
                border-radius: 3px;
                Text { text: "  ＋  Add Tetrahedron"; color: #8aabff; font-size: 12px; vertical-alignment: center; }
                t-touch := TouchArea {
                    clicked() => { root.add-object-at(root.click-ratio, 0); root.show-context-menu = false; }
                }
            }

            Rectangle {
                background: c-touch.has-hover ? #303038 : transparent;
                height: 30px;
                border-radius: 3px;
                Text { text: "  ＋  Add Cube"; color: #6ad8a0; font-size: 12px; vertical-alignment: center; }
                c-touch := TouchArea {
                    clicked() => { root.add-object-at(root.click-ratio, 1); root.show-context-menu = false; }
                }
            }

            Rectangle {
                background: tx-touch.has-hover ? #303038 : transparent;
                height: 30px;
                border-radius: 3px;
                Text { text: "  ＋  Add Text"; color: #c0a0ff; font-size: 12px; vertical-alignment: center; }
                tx-touch := TouchArea {
                    clicked() => { root.add-object-at(root.click-ratio, 2); root.show-context-menu = false; }
                }
            }
        }
    }
}
