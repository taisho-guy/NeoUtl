// src/ui/timeline.slint
import { IconSet } from "@lucide";
import { IconButton } from "common.slint";
import { TimelineObject, LayerState, SceneTabItem } from "types.slint";
import { Ruler } from "timeline/ruler.slint";
import { LayerHeader } from "timeline/layer-header.slint";
import { TimelineView } from "timeline/timeline-view.slint";

export component TimelineWindow inherits Window {
    title: "NeoUtl - 拡張編集";
    preferred-width: 1000px;
    preferred-height: 348px;
    min-height: 200px;
    background: #0e0e12;

    in-out property <int> current-frame: 0;
    in-out property <int> total-frames: 300;
    in-out property <int> layer-count: 128;
    in-out property <float> zoom-scale: 1.0;
    in-out property <int> selected-layer: 0;
    in-out property <[TimelineObject]> objects: [];
    in-out property <[LayerState]> layer-states: [];
    in-out property <[SceneTabItem]> scene-tabs: [];

    callback seek-timeline(int);
    callback add-object-at(int /* frame */, int /* layer */, int /* kind */);
    callback delete-object(int);
    callback select-object(int);
    callback move-object(int /* id */, int /* start-frame */, int /* layer */);
    callback resize-object(int /* id */, int /* start-frame */, int /* end-frame */);
    callback set-zoom(float);
    callback toggle-layer-visible(int);
    callback toggle-layer-locked(int);
    callback switch-scene-tab(int);
    callback open-scene-settings-create();
    callback open-scene-settings-edit(int);
    callback close-scene-tab(int);

    property <int> header-width: 60;
    property <int> layer-height: 24;
    property <int> frame-interval: root.zoom-scale > 3.0 ? 10 : root.zoom-scale > 1.0 ? 30 : root.zoom-scale > 0.3 ? 60 : 300;

    property <length> scroll-x: 0px;
    property <length> scroll-y: 0px;
    property <length> content-width: root.total-frames * root.zoom-scale * 1px;
    property <length> content-height: root.layer-count * root.layer-height * 1px;

    property <bool> show-context-menu: false;
    property <bool> menu-is-delete: false;
    property <int> menu-target-id: -1;
    property <int> menu-frame: 0;
    property <int> menu-layer: 0;
    property <length> menu-x: 0px;
    property <length> menu-y: 0px;

    FocusScope {
        key-pressed(event) => {
            if (event.text == Key.Delete && root.menu-target-id >= 0) {
                root.delete-object(root.menu-target-id);
            }
            accept
        }
        TouchArea {
            pointer-event(e) => {
                if (e.button == PointerEventButton.left && e.kind == PointerEventKind.down) {
                    root.show-context-menu = false;
                }
            }
        }
    }

    VerticalLayout {
        Rectangle {
            height: 28px;
            background: #16161c;

            HorizontalLayout {
                padding: 4px;
                spacing: 2px;

                for tab[i] in root.scene-tabs: Rectangle {
                    width: 120px;
                    border-radius: 3px;
                    background: tab.active ? #2a2a32 : (st.has-hover ? #202026 : transparent);
                    border-width: tab.active ? 1px : 0px;
                    border-color: #3a5fd9;

                    HorizontalLayout {
                        padding-left: 8px;
                        spacing: 4px;

                        Text {
                            text: tab.name;
                            color: tab.active ? #ffffff : #999aa4;
                            font-size: 11px;
                            vertical-alignment: center;
                            horizontal-stretch: 1;
                            overflow: elide;
                        }

                        IconButton {
                            icon: IconSet.Settings;
                            icon-size: 11px;
                            clicked() => { root.open-scene-settings-edit(tab.id); }
                        }

                        IconButton {
                            icon: IconSet.X;
                            icon-size: 11px;
                            clicked() => { root.close-scene-tab(tab.id); }
                        }
                    }

                    st := TouchArea {
                        clicked() => { root.switch-scene-tab(tab.id); }
                    }
                }

                IconButton {
                    icon: IconSet.Plus;
                    clicked() => { root.open-scene-settings-create(); }
                }
            }
        }

        Ruler {
            scale: root.zoom-scale;
            scroll-x: root.scroll-x;
            fps: 30;
            current-frame: root.current-frame;
            total-frames: root.total-frames;
            header-width: root.header-width * 1px;
            scrub(frame) => { root.seek-timeline(frame); }
            zoom(new-scale) => { root.zoom-scale = max(0.1, min(10.0, new-scale)); root.set-zoom(root.zoom-scale); }
        }

        HorizontalLayout {
            vertical-stretch: 1;
            layer-header := LayerHeader {
                header-width: root.header-width * 1px;
                layer-height: root.layer-height * 1px;
                layer-count: root.layer-count;
                scroll-y: root.scroll-y;
                selected-layer: root.selected-layer;
                layer-states: root.layer-states;
                toggle-visible(layer) => { root.toggle-layer-visible(layer); }
                toggle-locked(layer) => { root.toggle-layer-locked(layer); }
                select-layer(layer) => { root.selected-layer = layer; }
                scroll-requested(dy) => {
                    root.scroll-y = max(0px, min(root.scroll-y - dy, max(0px, root.content-height - layer-header.height)));
                }
            }

            view := TimelineView {
                scale: root.zoom-scale;
                frame-interval: root.frame-interval;
                total-frames: root.total-frames;
                layer-count: root.layer-count;
                layer-height: root.layer-height * 1px;
                current-frame: root.current-frame;
                objects: root.objects;
                layer-states: root.layer-states;
                scroll-x: root.scroll-x;
                scroll-y: root.scroll-y;

                seek(frame) => { root.seek-timeline(frame); }
                select-object(id) => { root.select-object(id); }
                move-object(id, start, layer) => { root.move-object(id, start, layer); }
                resize-object(id, start, end) => { root.resize-object(id, start, end); }
                scroll-requested(dx) => {
                    root.scroll-x = max(0px, min(root.scroll-x - dx, max(0px, root.content-width - view.width)));
                }
                context-menu(x, y, frame, layer, hit-id) => {
                    root.menu-frame = frame;
                    root.menu-layer = layer;
                    root.menu-target-id = hit-id;
                    root.menu-is-delete = hit-id >= 0;
                    root.menu-x = x;
                    root.menu-y = y + 4px;
                    root.show-context-menu = true;
                }
            }
        }
    }

    if (root.show-context-menu): Rectangle {
        x: root.menu-x;
        y: root.menu-y;
        width: 170px;
        height: root.menu-is-delete ? 40px : 106px;
        background: #252528;
        border-width: 1px;
        border-color: #48484e;
        border-radius: 5px;
        drop-shadow-blur: 10px;
        drop-shadow-color: #00000088;
        drop-shadow-offset-x: 2px;
        drop-shadow-offset-y: 2px;

        if (root.menu-is-delete): VerticalLayout {
            padding: 4px;
            Rectangle {
                background: del-touch.has-hover ? #4a1515 : transparent;
                height: 30px;
                border-radius: 3px;
                Text {
                    text: "  🗑  Delete Object";
                    color: #ff8888;
                    font-size: 12px;
                    vertical-alignment: center;
                }

                del-touch := TouchArea {
                    clicked() => { root.delete-object(root.menu-target-id); root.show-context-menu = false; }
                }
            }
        }

        if (!root.menu-is-delete): VerticalLayout {
            padding: 4px;
            spacing: 1px;

            Rectangle {
                background: t-touch.has-hover ? #303038 : transparent;
                height: 30px;
                border-radius: 3px;
                Text {
                    text: "  ＋  Add Tetrahedron";
                    color: #8aabff;
                    font-size: 12px;
                    vertical-alignment: center;
                }

                t-touch := TouchArea {
                    clicked() => { root.add-object-at(root.menu-frame, root.menu-layer, 0); root.show-context-menu = false; }
                }
            }

            Rectangle {
                background: c-touch.has-hover ? #303038 : transparent;
                height: 30px;
                border-radius: 3px;
                Text {
                    text: "  ＋  Add Cube";
                    color: #6ad8a0;
                    font-size: 12px;
                    vertical-alignment: center;
                }

                c-touch := TouchArea {
                    clicked() => { root.add-object-at(root.menu-frame, root.menu-layer, 1); root.show-context-menu = false; }
                }
            }

            Rectangle {
                background: tx-touch.has-hover ? #303038 : transparent;
                height: 30px;
                border-radius: 3px;
                Text {
                    text: "  ＋  Add Text";
                    color: #c0a0ff;
                    font-size: 12px;
                    vertical-alignment: center;
                }

                tx-touch := TouchArea {
                    clicked() => { root.add-object-at(root.menu-frame, root.menu-layer, 2); root.show-context-menu = false; }
                }
            }
        }
    }
}
