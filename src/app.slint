// src/app.slint

export struct TimelineObject {
    id: int,
    start_frame: int,
    end_frame: int,
    /// 0=Tetrahedron  1=Cube  2=Text
    kind: int,
    label: string,
}

export component MainWindow inherits Window {
    preferred-width: 820px;
    preferred-height: 720px;
    title: "NeoUtl";
    background: #0e0e12;

    // ── ビデオ / タイムライン プロパティ ──
    in-out property <image>  video-frame;
    in-out property <int>    current-frame: 0;
    in-out property <int>    total-frames: 300;
    in-out property <[TimelineObject]> objects: [];

    // ── プロジェクト設定プロパティ ──
    in-out property <int>    fps: 30;
    in-out property <int>    res-width: 1920;
    in-out property <int>    res-height: 1080;

    // ── Rust 実装コールバック ──
    callback add-object-at(float, int);     // (ratio, kind_idx)
    callback delete-object(int);            // (id)
    callback seek-timeline(float);          // (ratio)
    callback move-object(int, float);       // (id, new_start_ratio)
    callback request-render();
    callback find-object-at(float) -> int;
    callback get-object-start-ratio(int) -> float;
    callback set-fps(int);                  // FPS 変更
    callback set-resolution(int, int);      // 解像度変更 (width, height)

    // ── コンテキストメニュー状態 ──
    property <bool>   show-context-menu: false;
    property <bool>   menu-is-delete: false;
    property <int>    menu-target-id: -1;
    property <length> menu-x: 0px;
    property <length> menu-y: 0px;
    property <float>  click-ratio: 0.0;

    // ── ドラッグ状態: 0=idle, 1=seeking, 2=dragging-object ──
    property <int>    drag-mode: 0;
    property <int>    dragging-obj-id: -1;
    property <length> drag-mouse-start: 0px;
    property <float>  drag-obj-start-ratio: 0.0;

    Timer {
        interval: 16ms;
        running: true;
        triggered() => { root.request-render(); }
    }

    FocusScope {
        key-pressed(event) => { accept }
        TouchArea {
            pointer-event(e) => {
                if (e.button == PointerEventButton.left && e.kind == PointerEventKind.down) {
                    root.show-context-menu = false;
                }
            }
        }
    }

    VerticalLayout {
        padding: 12px;
        spacing: 8px;

        // ━━━ ビデオプレビュー ━━━
        Rectangle {
            background: #0a0a0e;
            border-radius: 4px;
            border-width: 1px;
            border-color: #222228;
            height: 380px;
            Image {
                source: root.video-frame;
                width: 100%;
                height: 100%;
                image-fit: contain;
            }
        }

        // ── ヒント ──
        Text {
            text: "左ドラッグ: シーク  |  オブジェクト左ドラッグ: 移動  |  右クリック: メニュー";
            color: #555560;
            font-size: 10px;
            horizontal-alignment: center;
        }

        // ━━━ タイムライン本体 ━━━
        timeline-rect := Rectangle {
            background: #1a1a20;
            border-radius: 4px;
            border-width: 1px;
            border-color: #2a2a32;
            height: 80px;

            // 再生ヘッド
            Rectangle {
                background: #ff4500;
                width: 2px;
                height: parent.height;
                x: (root.current-frame / root.total-frames) * parent.width;
            }

            // オブジェクト矩形（kind ごとに色分け）
            for obj in root.objects : Rectangle {
                property <bool> is-drag: root.drag-mode == 2 && root.dragging-obj-id == obj.id;

                // kind: 0=Tetrahedron(青), 1=Cube(緑), 2=Text(紫)
                property <color> base-color:
                    obj.kind == 0 ? #2a4db8 :
                    obj.kind == 1 ? #256e3c :
                                    #6a2db8;
                property <color> drag-color:
                    obj.kind == 0 ? #4a6fd8 :
                    obj.kind == 1 ? #3d9e5c :
                                    #8a4dd8;
                property <color> border-color-val:
                    obj.kind == 0 ? #6a90f0 :
                    obj.kind == 1 ? #5dc87a :
                                    #aa70f0;

                background: is-drag ? drag-color : base-color;
                border-width: 1px;
                border-color: is-drag ? border-color-val : base-color.darker(0.3);
                border-radius: 3px;
                y: 8px;
                height: 64px;
                x: (obj.start-frame / root.total-frames) * parent.width;
                width: ((obj.end-frame - obj.start-frame) / root.total-frames) * parent.width;

                Text {
                    text: obj.label;
                    color: white;
                    font-size: 10px;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                    overflow: elide;
                }
            }

            // タイムライン TouchArea（唯一のイベント処理）
            timeline-touch := TouchArea {
                mouse-cursor: root.drag-mode == 2 ? MouseCursor.grabbing
                            : root.drag-mode == 1 ? MouseCursor.col-resize
                            : MouseCursor.default;

                pointer-event(e) => {
                    if (e.kind == PointerEventKind.down) {
                        root.show-context-menu = false;
                        let press-ratio = self.pressed-x / self.width;

                        if (e.button == PointerEventButton.right) {
                            let hit-id = root.find-object-at(press-ratio);
                            root.click-ratio = press-ratio;
                            root.menu-target-id = hit-id;
                            root.menu-is-delete = hit-id >= 0;
                            root.menu-x = timeline-rect.absolute-position.x + self.pressed-x;
                            root.menu-y = timeline-rect.absolute-position.y + self.pressed-y + 4px;
                            root.show-context-menu = true;
                        } else if (e.button == PointerEventButton.left) {
                            root.drag-mouse-start = self.pressed-x;
                            let hit-id = root.find-object-at(press-ratio);
                            if (hit-id >= 0) {
                                root.drag-mode = 2;
                                root.dragging-obj-id = hit-id;
                                root.drag-obj-start-ratio = root.get-object-start-ratio(hit-id);
                            } else {
                                root.drag-mode = 1;
                                root.seek-timeline(press-ratio);
                            }
                        }
                    }
                    if (e.kind == PointerEventKind.up || e.kind == PointerEventKind.cancel) {
                        root.drag-mode = 0;
                        root.dragging-obj-id = -1;
                    }
                }

                moved() => {
                    if (root.drag-mode == 1) {
                        root.seek-timeline((self.mouse-x / self.width).clamp(0.0, 1.0));
                    } else if (root.drag-mode == 2) {
                        let delta = (self.mouse-x - root.drag-mouse-start) / self.width;
                        let new-r = (root.drag-obj-start-ratio + delta).clamp(0.0, 1.0);
                        root.move-object(root.dragging-obj-id, new-r);
                    }
                }
            }
        }

        // ── フレーム情報 ──
        Text {
            text: "Frame: " + root.current-frame + " / " + root.total-frames +
                  "  |  " + root.fps + " fps  |  " +
                  root.res-width + " × " + root.res-height;
            horizontal-alignment: center;
            color: #888894;
            font-size: 11px;
        }

        // ━━━ プロジェクト設定パネル ━━━
        Rectangle {
            background: #141418;
            border-radius: 5px;
            border-width: 1px;
            border-color: #24242c;
            height: 68px;

            HorizontalLayout {
                padding-left: 14px;
                padding-right: 14px;
                padding-top: 8px;
                padding-bottom: 8px;
                spacing: 20px;
                alignment: LayoutAlignment.start;

                // ── FPS ──────────────────────────
                VerticalLayout {
                    spacing: 5px;
                    alignment: LayoutAlignment.start;

                    Text { text: "FPS"; color: #55555e; font-size: 10px; }

                    HorizontalLayout {
                        spacing: 4px;

                        // 24 fps
                        fps24 := Rectangle {
                            width: 34px; height: 24px; border-radius: 3px;
                            background: root.fps == 24 ? #2a4db8 : #1e1e24;
                            border-width: 1px;
                            border-color: root.fps == 24 ? #6a90f0 : #303038;
                            Text { text: "24"; color: root.fps == 24 ? #dde8ff : #666672;
                                   font-size: 11px; horizontal-alignment: center; vertical-alignment: center; }
                            TouchArea { clicked() => { root.set-fps(24); } }
                        }

                        // 30 fps
                        fps30 := Rectangle {
                            width: 34px; height: 24px; border-radius: 3px;
                            background: root.fps == 30 ? #2a4db8 : #1e1e24;
                            border-width: 1px;
                            border-color: root.fps == 30 ? #6a90f0 : #303038;
                            Text { text: "30"; color: root.fps == 30 ? #dde8ff : #666672;
                                   font-size: 11px; horizontal-alignment: center; vertical-alignment: center; }
                            TouchArea { clicked() => { root.set-fps(30); } }
                        }

                        // 60 fps
                        fps60 := Rectangle {
                            width: 34px; height: 24px; border-radius: 3px;
                            background: root.fps == 60 ? #2a4db8 : #1e1e24;
                            border-width: 1px;
                            border-color: root.fps == 60 ? #6a90f0 : #303038;
                            Text { text: "60"; color: root.fps == 60 ? #dde8ff : #666672;
                                   font-size: 11px; horizontal-alignment: center; vertical-alignment: center; }
                            TouchArea { clicked() => { root.set-fps(60); } }
                        }

                        // 120 fps
                        fps120 := Rectangle {
                            width: 40px; height: 24px; border-radius: 3px;
                            background: root.fps == 120 ? #2a4db8 : #1e1e24;
                            border-width: 1px;
                            border-color: root.fps == 120 ? #6a90f0 : #303038;
                            Text { text: "120"; color: root.fps == 120 ? #dde8ff : #666672;
                                   font-size: 11px; horizontal-alignment: center; vertical-alignment: center; }
                            TouchArea { clicked() => { root.set-fps(120); } }
                        }
                    }
                }

                // 縦区切り
                Rectangle { width: 1px; background: #24242c; }

                // ── 解像度 ────────────────────────
                VerticalLayout {
                    spacing: 5px;
                    alignment: LayoutAlignment.start;

                    Text { text: "解像度"; color: #55555e; font-size: 10px; }

                    HorizontalLayout {
                        spacing: 4px;

                        // HD 1280×720
                        resHD := Rectangle {
                            width: 40px; height: 24px; border-radius: 3px;
                            background: root.res-width == 1280 ? #1e5c34 : #1e1e24;
                            border-width: 1px;
                            border-color: root.res-width == 1280 ? #4dc87a : #303038;
                            Text { text: "HD"; color: root.res-width == 1280 ? #c0f0d0 : #666672;
                                   font-size: 11px; horizontal-alignment: center; vertical-alignment: center; }
                            TouchArea { clicked() => { root.set-resolution(1280, 720); } }
                        }

                        // FHD 1920×1080
                        resFHD := Rectangle {
                            width: 44px; height: 24px; border-radius: 3px;
                            background: root.res-width == 1920 ? #1e5c34 : #1e1e24;
                            border-width: 1px;
                            border-color: root.res-width == 1920 ? #4dc87a : #303038;
                            Text { text: "FHD"; color: root.res-width == 1920 ? #c0f0d0 : #666672;
                                   font-size: 11px; horizontal-alignment: center; vertical-alignment: center; }
                            TouchArea { clicked() => { root.set-resolution(1920, 1080); } }
                        }

                        // 4K 3840×2160
                        res4K := Rectangle {
                            width: 34px; height: 24px; border-radius: 3px;
                            background: root.res-width == 3840 ? #1e5c34 : #1e1e24;
                            border-width: 1px;
                            border-color: root.res-width == 3840 ? #4dc87a : #303038;
                            Text { text: "4K"; color: root.res-width == 3840 ? #c0f0d0 : #666672;
                                   font-size: 11px; horizontal-alignment: center; vertical-alignment: center; }
                            TouchArea { clicked() => { root.set-resolution(3840, 2160); } }
                        }
                    }
                }
            }
        }
    }

    // ━━━ コンテキストメニュー ━━━
    if (root.show-context-menu) : Rectangle {
        x: root.menu-x;
        y: root.menu-y;
        width: 170px;
        height: root.menu-is-delete ? 40px : 106px;
        background: #252528;
        border-width: 1px;
        border-color: #48484e;
        border-radius: 5px;
        drop-shadow-blur: 10px;
        drop-shadow-color: #00000088;
        drop-shadow-offset-x: 2px;
        drop-shadow-offset-y: 2px;

        // 削除メニュー
        if (root.menu-is-delete) : VerticalLayout {
            padding: 4px;
            Rectangle {
                background: del-touch.has-hover ? #4a1515 : transparent;
                height: 30px; border-radius: 3px;
                Text { text: "  🗑  Delete Object"; color: #ff8888; font-size: 12px; vertical-alignment: center; }
                del-touch := TouchArea {
                    clicked() => { root.delete-object(root.menu-target-id); root.show-context-menu = false; }
                }
            }
        }

        // 追加メニュー（Tetrahedron / Cube / Text）
        if (!root.menu-is-delete) : VerticalLayout {
            padding: 4px;
            spacing: 1px;

            Rectangle {
                background: t-touch.has-hover ? #303038 : transparent;
                height: 30px; border-radius: 3px;
                Text { text: "  ＋  Add Tetrahedron"; color: #8aabff; font-size: 12px; vertical-alignment: center; }
                t-touch := TouchArea {
                    clicked() => { root.add-object-at(root.click-ratio, 0); root.show-context-menu = false; }
                }
            }

            Rectangle {
                background: c-touch.has-hover ? #303038 : transparent;
                height: 30px; border-radius: 3px;
                Text { text: "  ＋  Add Cube"; color: #6ad8a0; font-size: 12px; vertical-alignment: center; }
                c-touch := TouchArea {
                    clicked() => { root.add-object-at(root.click-ratio, 1); root.show-context-menu = false; }
                }
            }

            Rectangle {
                background: tx-touch.has-hover ? #303038 : transparent;
                height: 30px; border-radius: 3px;
                Text { text: "  ＋  Add Text"; color: #c0a0ff; font-size: 12px; vertical-alignment: center; }
                tx-touch := TouchArea {
                    clicked() => { root.add-object-at(root.click-ratio, 2); root.show-context-menu = false; }
                }
            }
        }
    }
}
