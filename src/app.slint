export struct TimelineObject {
    id: int,
    start_frame: int,
    end_frame: int,
}

export component MainWindow inherits Window {
    preferred-width: 800px;
    preferred-height: 680px;
    title: "NeoUtl - Video Editor Prototype (WGPU 29)";

    in-out property <image> video-frame;
    in-out property <int> current-frame: 0;
    in-out property <int> total-frames: 300;
    in-out property <[TimelineObject]> objects: [];
    
    callback request-render();
    callback seek-timeline(float);
    callback add-object-at(float);
    callback delete-object(int);

    Timer {
        interval: 16ms;
        running: true;
        triggered() => { root.request-render(); }
    }

    VerticalLayout {
        padding: 20px;
        spacing: 15px;
        
        Text {
            text: "NeoUtl: wgpu 29 + Slint Non-Linear Editing Pipeline";
            font-size: 20px;
            horizontal-alignment: center;
        }

        Rectangle {
            background: #121214;
            height: 400px;
            border-radius: 6px;
            Image {
                source: root.video-frame;
                width: 100%;
                height: 100%;
            }
        }

        HorizontalLayout {
            Text {
                text: "Frame: " + root.current-frame + " / " + root.total-frames;
                font-size: 14px;
                color: #e0e0e0;
            }
        }

        VerticalLayout {
            spacing: 5px;
            Text { 
                text: "Timeline (Left-Click/Drag: Seek | Right-Click Blank: Add | Right-Click Object: Delete)"; 
                font-size: 11px; 
                color: #888888; 
            }
            
            track := Rectangle {
                background: #202024;
                height: 60px;
                border-radius: 4px;
                border-width: 1px;
                border-color: #303036;

                track-touch := TouchArea {
                    pointer-event(event) => {
                        if (event.button == PointerEventButton.left && (event.kind == PointerEventKind.down || event.kind == PointerEventKind.move)) {
                            root.seek-timeline(self.mouse-x / self.width);
                        }
                        if (event.button == PointerEventButton.right && event.kind == PointerEventKind.down) {
                            root.add-object-at(self.mouse-x / self.width);
                        }
                    }
                }

                for obj in root.objects : Rectangle {
                    x: (obj.start_frame * track.width) / root.total-frames;
                    width: ((obj.end_frame - obj.start_frame) * track.width) / root.total-frames;
                    height: track.height - 12px;
                    y: 6px;
                    background: #2563eb;
                    border-radius: 4px;
                    border-width: 1px;
                    border-color: #3b82f6;

                    Text {
                        text: "Tetrahedron [" + obj.start_frame + " - " + obj.end_frame + "f]";
                        color: #ffffff;
                        font-size: 11px;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }

                    TouchArea {
                        pointer-event(event) => {
                            if (event.button == PointerEventButton.right && event.kind == PointerEventKind.down) {
                                root.delete-object(obj.id);
                            }
                        }
                    }
                }

                Rectangle {
                    x: (root.current-frame * track.width) / root.total-frames;
                    width: 2px;
                    height: track.height;
                    background: #ef4444;
                }
            }
        }
    }
}