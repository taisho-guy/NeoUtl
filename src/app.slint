// src/app.slint

export struct TimelineObject {
    id: int,
    start_frame: int,
    end_frame: int,
}

export component MainWindow inherits Window {
    preferred-width: 800px;
    preferred-height: 650px;
    title: "NeoUtl";

    in-out property <image> video-frame;
    in-out property <int> current-frame: 0;
    in-out property <int> total-frames: 300;
    in-out property <[TimelineObject]> objects: [];

    callback add-object-at(float, int);
    callback delete-object(int);
    callback seek-timeline(float);
    callback request-render();

    property <bool> show-context-menu: false;
    property <length> menu-x: 0;
    property <length> menu-y: 0;
    property <float> click-ratio: 0.0;

    Timer {
        interval: 16ms;
        running: true;
        triggered() => { root.request-render(); }
    }

    FocusScope {
        key-pressed(event) => { accept }
        TouchArea {
            pointer-event(e) => {
                if (e.button == PointerEventButton.left && e.kind == PointerEventKind.down) {
                    root.show-context-menu = false;
                }
            }
        }
    }

    VerticalLayout {
        padding: 15px;
        spacing: 10px;

        Rectangle {
            background: #121214;
            height: 400px;
            Image {
                source: root.video-frame;
                width: 100%;
                height: 100%;
            }
        }

        Text {
            text: "Timeline (右クリックでオブジェクトを追加 / 右クリックでオブジェクトを削除)";
            color: #aaaaaa;
        }

        Rectangle {
            background: #1e1e22;
            border-radius: 4px;
            height: 80px;

            timeline-touch := TouchArea {
                pointer-event(e) => {
                    if (e.button == PointerEventButton.right && e.kind == PointerEventKind.down) {
                        root.click-ratio = timeline-touch.pressed-x / timeline-touch.width;
                        root.menu-x = timeline-touch.pressed-x;
                        root.menu-y = timeline-touch.pressed-y + 30px; 
                        root.show-context-menu = true;
                    }
                }
            }

            Rectangle {
                background: #ff4500;
                width: 2px;
                x: (root.current-frame / root.total-frames) * parent.width;
            }

            for obj in root.objects : Rectangle {
                background: #3a5fcd;
                border-width: 1px;
                border-color: #63b8ff;
                border-radius: 2px;
                y: 10px;
                height: 40px;
                x: (obj.start-frame / root.total-frames) * parent.width;
                width: ((obj.end-frame - obj.start-frame) / root.total-frames) * parent.width;

                Text {
                    text: "ID: " + obj.id;
                    color: white;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }

                obj-touch := TouchArea {
                    pointer-event(e) => {
                        if (e.button == PointerEventButton.right && e.kind == PointerEventKind.down) {
                            root.delete-object(obj.id);
                        }
                    }
                }
            }
        }

        Text {
            text: "Frame: " + root.current-frame + " / " + root.total-frames;
            horizontal-alignment: center;
        }
    }

    if (root.show-context-menu) : Rectangle {
        x: root.menu-x;
        y: root.menu-y;
        width: 150px;
        height: 60px;
        background: #2d2d30;
        border-width: 1px;
        border-color: #434346;
        border-radius: 4px;

        VerticalLayout {
            padding: 2px;
            
            Rectangle {
                background: item1-touch.has-hover ? #3e3e42 : #2d2d30;
                height: 28px;
                Text { text: "  + Add Tetrahedron"; color: white; vertical-alignment: center; }
                item1-touch := TouchArea {
                    clicked() => {
                        root.add-object-at(root.click-ratio, 0); // 0 = Tetrahedron
                        root.show-context-menu = false;
                    }
                }
            }
            
            Rectangle {
                background: item2-touch.has-hover ? #3e3e42 : #2d2d30;
                height: 28px;
                Text { text: "  + Add Cube"; color: white; vertical-alignment: center; }
                item2-touch := TouchArea {
                    clicked() => {
                        root.add-object-at(root.click-ratio, 1); // 1 = Cube
                        root.show-context-menu = false;
                    }
                }
            }
        }
    }
}