{
    "id": "scene",
    "name": "シーンオブジェクト",
    "qml": "SceneObject.qml",
    "params": {
        "targetSceneId": -1,
        "speed": 1.0,
        "offset": 0,
        "opacity": 1.0
    },
    "ui": {
        "group": "object",
        "controls": [
            {
                "type": "combo",
                "param": "targetSceneId",
                "label": "シーン",
                "source": "Workspace.currentTimeline",
                "sourceProperty": "scenes",
                "excludeCurrentScene": true
            },
            {
                "type": "slider",
                "param": "speed",
                "label": "再生速度",
                "min": 0.1,
                "max": 4.0,
                "step": 0.1
            },
            {
                "type": "spinner",
                "param": "offset",
                "label": "オフセット",
                "min": 0,
                "max": 100000
            },
            {
                "type": "slider",
                "param": "opacity",
                "label": "不透明度",
                "min": 0.0,
                "max": 1.0,
                "step": 0.01
            }
        ]
    },
    "version": "1.0.0",
    "kind": "object",
    "categories": [
        "基本"
    ]
}
