{
    "id": "audio",
    "name": "音声",
    "qml": "AudioObject.qml",
    "color": "#d03030",
    "params": {
        "source": "",
        "playMode": "開始時間＋再生速度",
        "startTime": 0,
        "speed": 100.0,
        "directTime": 0,
        "volume": 1.0,
        "pan": 0.0,
        "mute": false
    },
    "ui": {
        "controls": [
            {
                "type": "path",
                "param": "source",
                "label": "ファイル",
                "filter": "Audio Files (*.wav *.mp3 *.aac *.m4a *.flac *.ogg)"
            },
            {
                "type": "enum",
                "param": "playMode",
                "label": "再生モード",
                "options": [
                    "開始時間＋再生速度",
                    "時間直接指定"
                ]
            },
            {
                "type": "header",
                "label": "開始時間＋再生速度"
            },
            {
                "type": "float",
                "param": "startTime",
                "label": "開始時間",
                "min": 0,
                "unit": "s"
            },
            {
                "type": "float",
                "param": "speed",
                "label": "再生速度",
                "min": 1,
                "max": 400,
                "default": 100,
                "unit": "%"
            },
            {
                "type": "header",
                "label": "時間直接指定"
            },
            {
                "type": "float",
                "param": "directTime",
                "label": "指定時間",
                "min": 0,
                "unit": "s"
            },
            {
                "type": "header",
                "label": "オーディオ設定"
            },
            {
                "type": "slider",
                "param": "volume",
                "label": "音量",
                "min": 0,
                "max": 2,
                "step": 0.01
            },
            {
                "type": "slider",
                "param": "pan",
                "label": "パン",
                "min": -1,
                "max": 1,
                "step": 0.1
            },
            {
                "type": "bool",
                "param": "mute",
                "label": "ミュート"
            }
        ]
    },
    "version": "1.0.0",
    "kind": "object",
    "categories": [
        "メディア/音声"
    ]
}
