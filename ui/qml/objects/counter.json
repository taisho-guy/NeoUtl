        "opacity": 1.0
    },
    "ui": {
        "controls": [
            {"type": "enum", "param": "mode", "label": "表示形式", "options": [{"value": "frame", "label": "フレーム"}, {"value": "time", "label": "秒"}, {"value": "value", "label": "値"}]},
            {"type": "float", "param": "startValue", "label": "開始値", "decimals": 2},
            {"type": "float", "param": "endValue", "label": "終了値", "decimals": 2},
            {"type": "int", "param": "digits", "label": "桁数", "min": 0, "max": 12},
