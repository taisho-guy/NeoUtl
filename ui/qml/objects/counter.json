            {"type": "color", "param": "outlineColor", "label": "縁取り色"},
            {"type": "float", "param": "outlineWidth", "label": "縁取り幅", "min": 0, "max": 50},
            {"type": "slider", "param": "opacity", "label": "不透明度", "min": 0, "max": 1, "step": 0.01}
        ]
